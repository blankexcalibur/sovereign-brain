# Sovereign Memory Daemon — Configuration
# Copy this file to .env and adjust as needed.

# Database path (defaults to .memory-brain/brain.db)
# MEMORY_BRAIN_DB_PATH=./data/brain.db

# Team Mode: comma-separated API keys for multi-tenant auth
# MEMORY_API_KEYS=key_alice_abc123,key_bob_def456

# Force team mode (binds to 0.0.0.0 instead of localhost)
# MEMORY_TEAM_MODE=true

# Enable debug logging
# DEBUG=true
