{
  "name": "sovereign-brain",
  "version": "2.0.0",
  "description": "Shared memory layer for AI coding agents. One brain, every tool. MCP-native.",
  "main": "index.js",
  "bin": {
    "sovereign-brain": "./index.js"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cognitive-systems/sovereign-brain"
  },
  "homepage": "https://github.com/cognitive-systems/sovereign-brain#readme",
  "files": [
    "index.js",
    "src/brain/",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "start": "node --expose-gc index.js",
    "dev": "nodemon index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "memory": "node --expose-gc src/brain/cli.js",
    "memory:seed": "node src/brain/seed.js",
    "mcp": "node index.js --mcp",
    "install-claude": "node index.js install-claude",
    "test:brain": "node --experimental-vm-modules node_modules/jest/bin/jest.js src/tests/brain --runInBand",
    "build:binary": "pkg . --target node20-win-x64,node20-linux-x64,node20-macos-x64",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai-agents",
    "rag",
    "vector-database",
    "sqlite",
    "local-first"
  ],
  "author": "Cognitive Systems Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.2",
    "chokidar": "^4.0.3",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hnswlib-node": "^3.0.0",
    "natural": "^6.10.4",
    "p-queue": "^8.0.1",
    "prom-client": "^15.1.3",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
